# POLLY — AI Marketing CLI for Financial Advisors
# Copy this file to .env and fill in your actual credentials

# ============================================================================
# Required: XAI (Grok) for LLM content generation
# ============================================================================

# XAI API Key - Required for all content generation
# Get from: https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# XAI Model (default: grok-3, alternatives: grok-4-fast-reasoning, grok-2)
XAI_MODEL=grok-3

# ============================================================================
# Optional: Arcade AI for social media posting (X/LinkedIn)
# ============================================================================

ARCADE_API_KEY=your_arcade_api_key_here
ARCADE_USER_EMAIL=your_email@example.com
ARCADE_USER_PASSWORD=your_password_here
ARCADE_USER_ID=your_email@example.com

# ============================================================================
# Optional: Composio for channel integrations (CRM, Instagram, TikTok)
# ============================================================================

COMPOSIO_API_KEY=your_composio_api_key_here

# ============================================================================
# Optional: LinkedIn Company Page
# ============================================================================

LINKEDIN_PAGE=https://www.linkedin.com/company/your-company/

# ============================================================================
# Application Settings
# ============================================================================

POST_DELAY=5
DEBUG=false

# ============================================================================
# Notes
# ============================================================================
#
# 1. Never commit the .env file to version control
# 2. Keep your API keys and credentials secure
# 3. Minimum setup: just XAI_API_KEY is needed for content generation
# 4. The .env file is listed in .gitignore and will not be committed
#
